{
  "name": "space-browser",
  "version": "2.0.0",
  "description": "Space \u2013 A next-generation browser with built-in local AI inference. No cloud. No Ollama. Pure GGUF.",
  "productName": "Space",
  "main": "dist/main/main.js",
  "scripts": {
    "install": "node -e \"console.log('skip node-gyp: native addon is built with CMake via npm run build:native')\"",
    "start": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run electron\"",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "electron": "wait-on tcp:3000 && cross-env SPACE_DEV_MODE=1 electron .",
    "electron:prod": "electron .",
    "build": "npm run build:ts && npm run build:webpack",
    "build:ts": "tsc -p tsconfig.main.json",
    "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.renderer.config.js",
    "build:native": "node scripts/build-native.js",
    "build:icons": "node scripts/generate-icons.js",
    "build:all": "npm run build:ts && npm run build:webpack",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "npm run build:all && node scripts/dist-win.js",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "test": "jest"
  },
  "keywords": [
    "browser",
    "AI",
    "GGUF",
    "llama",
    "electron",
    "local-LLM"
  ],
  "author": "Space Browser Team",
  "license": "MPL-2.0",
  "dependencies": {
    "@mapbox/node-pre-gyp": "^1.0.11",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-addon-api": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.9.0",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.7.7",
    "postcss": "^8.4.33",
    "postcss-loader": "^7.3.4",
    "sass": "^1.70.0",
    "sass-loader": "^14.0.0",
    "sharp": "^0.34.5",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.space.browser",
    "productName": "Space",
    "copyright": "Copyright \u00a9 2026 Space Browser",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "dist/**/*",
          "assets/**/*",
          "package.json"
        ]
      },
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "electron-store/**/*",
          "electron-updater/**/*",
          "builder-util-runtime/**/*",
          "fs-extra/**/*",
          "lazy-val/**/*",
          "conf/**/*",
          "type-fest/**/*",
          "ajv/**/*",
          "ajv-formats/**/*",
          "atomically/**/*",
          "debounce-fn/**/*",
          "dot-prop/**/*",
          "env-paths/**/*",
          "json-schema-typed/**/*",
          "onetime/**/*",
          "pkg-up/**/*",
          "semver/**/*",
          "find-up/**/*",
          "locate-path/**/*",
          "p-locate/**/*",
          "p-limit/**/*",
          "yocto-queue/**/*",
          "path-exists/**/*",
          "mimic-fn/**/*",
          "fast-deep-equal/**/*",
          "fast-json-stable-stringify/**/*",
          "json-schema-traverse/**/*",
          "uri-js/**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "build/Release",
        "to": "build/Release",
        "filter": [
          "space_inference.node",
          "*.dll"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.dll"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "Space-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerHeader": "assets/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Space Browser",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "en_US"
      ],
      "license": "LICENSE",
      "uninstallDisplayName": "Space Browser ${version}",
      "guid": "A7B3C4D5-E6F7-4890-ABCD-EF1234567890",
      "include": null
    },
    "portable": {
      "artifactName": "Space-Portable-${version}.exe",
      "useZip": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "category": "Network"
    },
    "publish": {
      "provider": "github",
      "owner": "ShabanEjupi1",
      "repo": "SpaceBrowser",
      "releaseType": "release"
    }
  },
  "binary": {
    "module_name": "space_inference",
    "module_path": "./native/build/Release/",
    "host": "https://github.com/space-browser/space/releases/download/",
    "remote_path": "{version}"
  }
}